# Copy to .env and adjust as needed. The .env file is gitignored.

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info
# HTTP + WebSocket port for apps/api (serves /ws, /healthz, /metrics).
PORT=4000
# HTTP port for the generator's attack-simulator API (POST /simulate/:scenario).
GENERATOR_PORT=4200

# --- Kafka ---
# Host (apps running via `pnpm dev`) reach the broker on localhost:9092.
# Containers on the compose network would use kafka:19092 (internal listener).
KAFKA_BROKERS=localhost:9092

# --- PostgreSQL ---
POSTGRES_URL=postgresql://argus:argus@localhost:5432/argus
# Only needed if 5432 is already taken locally (e.g. a native Postgres install) —
# changes docker-compose's host-side port mapping; update POSTGRES_URL's port to match.
# POSTGRES_HOST_PORT=5433

# --- Elasticsearch ---
ES_NODE=http://localhost:9200

# --- Storage profile: 'full' (Elasticsearch, default) | 'lite' (Postgres FTS fallback) ---
STORAGE_PROFILE=full

# --- AI / LLM (optional) ---
# Leave blank to run with zero keys — the AI layer degrades to deterministic template summaries.
# Default free-tier provider: gemini (Google AI Studio) | groq | none
LLM_PROVIDER=none
GEMINI_API_KEY=
GROQ_API_KEY=

# --- Dashboard ---
# The Next.js dashboard reads NEXT_PUBLIC_* from its OWN env at build time
# (apps/dashboard/.env.local), not this root file. Point it at the api's WS port.
# NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# --- Demo ---
# When true, the generator runs a scripted attack timeline shortly after startup.
DEMO_MODE=false
