// Relational truth for alerts/incidents/summaries (architecture §5, §7). The
// event stream itself lives in Elasticsearch — Postgres never stores events,
// only the eventIds an alert/incident references. STORAGE_PROFILE=lite is the
// one exception: NormalizedEventRow below backs the event store in place of
// Elasticsearch, full-text-searched via a functional GIN index (raw SQL in
// the migration — Prisma has no schema syntax for functional indexes).

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

enum Severity {
  info
  low
  medium
  high
  critical
}

enum IncidentStatus {
  open
  acknowledged
  resolved
  false_positive
}

enum Summarizer {
  llm
  template
}

// a correlated group of alerts from one entity within a time window (§7).
// alertIds/eventIds are denormalized arrays kept in sync with the member
// alerts inside the same transaction — cheap reads matching the Incident
// wire contract exactly, at the cost of one source of truth living in two
// places (Alert.incidentId is the real relation; the arrays are a cache).
model Incident {
  incidentId     String         @id @map("incident_id")
  correlationKey String         @map("correlation_key")
  severity       Severity
  status         IncidentStatus @default(open)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @map("updated_at")
  alertIds       String[]       @map("alert_ids")
  eventIds       String[]       @map("event_ids")
  assigneeId     String?        @map("assignee_id")
  resolutionNote String?        @map("resolution_note")

  assignee User?    @relation(fields: [assigneeId], references: [userId])
  alerts   Alert[]
  summary  Summary?

  @@index([correlationKey, status, updatedAt])
  @@map("incidents")
}

// one rule firing. alertId/ruleId/timestamp etc. are assigned upstream by the
// detection engine (§6) — Prisma just persists what it's given.
model Alert {
  alertId    String   @id @map("alert_id")
  ruleId     String   @map("rule_id")
  severity   Severity
  timestamp  DateTime
  entity     String
  eventIds   String[] @map("event_ids")
  message    String
  count      Int?
  incidentId String   @map("incident_id")
  createdAt  DateTime @default(now()) @map("created_at")

  incident Incident @relation(fields: [incidentId], references: [incidentId])

  @@index([incidentId])
  @@map("alerts")
}

// AI (or template-degraded) incident summary — Day 8. Schema lands now so the
// Day 7 migration is the only one needed for the relational side of the plan.
model Summary {
  incidentId         String     @id @map("incident_id")
  summary            String
  iocs               String[]
  recommendedActions String[]   @map("recommended_actions")
  generatedBy        Summarizer @map("generated_by")
  generatedAt        DateTime   @map("generated_at")

  incident Incident @relation(fields: [incidentId], references: [incidentId])

  @@map("summaries")
}

// mirrors @argus/contracts' NormalizedEvent — the Postgres-FTS event store
// used when STORAGE_PROFILE=lite instead of Elasticsearch (§ above).
model NormalizedEventRow {
  eventId    String   @id @map("event_id")
  timestamp  DateTime
  source     String
  sourceIp   String   @map("source_ip")
  outcome    String
  username   String?
  method     String?
  path       String?
  statusCode Int?     @map("status_code")
  userAgent  String?  @map("user_agent")
  raw        String

  @@index([timestamp])
  @@index([source])
  @@map("normalized_events")
}

// per-user accounts (email+password and/or Google). passwordHash null =
// Google-only account; googleId null = email/password-only account. The same
// email via both paths links onto one row (see auth/users.ts upsertGoogleUser).
model User {
  userId       String   @id @map("user_id")
  email        String   @unique
  passwordHash String?  @map("password_hash")
  googleId     String?  @unique @map("google_id")
  name         String?
  createdAt    DateTime @default(now()) @map("created_at")

  assignedIncidents Incident[]

  @@map("users")
}
